# Copy to .env.local and fill in. Never commit .env.local.
# Vercel: add the same keys for Production, Preview, and Development.
# If Preview env add fails from CLI (Git branch), set Preview vars in the Vercel dashboard
# or connect the repo to Git. Use: npm run vercel:sync-dev-env (after production env pull) for Development.

# App URL (invite links, emails, server-side fetch to own API, OpenRouter HTTP-Referer when set)
# Production example: https://buildcraft-omega.vercel.app — on Vercel, VERCEL_URL is also used for OpenRouter if NEXT_PUBLIC_APP_URL is unset
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: display name on outgoing mail (Gmail, Resend plain-address wraps, Brevo default)
# EMAIL_FROM_NAME=BUILDCRAFT AI

# Gmail SMTP — send to any recipient without Resend domain verification (requires App Password)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=

# Firebase (client) — must match the Firebase project “Web app” in the console. On Vercel, copy
# every NEXT_PUBLIC_FIREBASE_* into Production. Also add this deployment host
# (e.g. your-app.vercel.app) to Firebase → Authentication → Settings → Authorized domains, and
# to Google Cloud → APIs & Services → Credentials → your OAuth 2.0 Web client:
# Authorized JavaScript origins = https://your-app.vercel.app (popup sign-in; no /__/auth/handler
# in origins — Firebase uses its own handler domain as needed).
NEXT_PUBLIC_FIREBASE_API_KEY=
# Production on Vercel: use your deployment hostname (e.g. buildcraft-omega.vercel.app) so /__/auth/* rewrites stay same-origin with next.config.ts. Local dev: use the *.firebaseapp.com value from the Firebase console, or localhost with authorized domain.
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server API routes: accept hire, Firestore admin, auth verify). Required on Vercel for “Accept offer”.
# Option A — one-line JSON from Firebase Console → Project settings → Service accounts → Generate new private key:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
#
# Option B — split variables (common on Vercel). Same service account. PRIVATE_KEY: include -----BEGIN/END-----;
# use real newlines in .env.local, or a single line with \n where line breaks go.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n....\n-----END PRIVATE KEY-----\n"
#
# If unset, the SDK tries Application Default Credentials (local gcloud only).

# Brevo — transactional email (hire invite, accept notice, chat notifications)
# 1) Brevo dashboard → SMTP & API → API keys → create a v3 key (often starts with xkeysib-)
# 2) Senders & domains → add and verify your domain (or verify a single sender email)
# 3) Copy this file to .env.local in this folder and set:
BREVO_API_KEY=
# Must match a verified sender (name + email). Example:
BREVO_FROM=BuildCraft AI <noreply@your-verified-domain.com>

# Optional SMTP fallback if BREVO_API_KEY is unset (SMTP & API → SMTP tab)
# BREVO_SMTP_LOGIN=
# BREVO_SMTP_KEY=
# BREVO_SMTP_PORT=587

# Resend — used when Brevo is not configured (https://resend.com/api-keys)
# RESEND_API_KEY=
# You cannot use @gmail.com as From unless you verify that domain on Resend (not possible for gmail.com).
# Dev: RESEND_FROM=BuildCraft AI <onboarding@resend.dev>
# Prod: add your domain at resend.com/domains, then e.g. noreply@yourdomain.com
# RESEND_FROM=BuildCraft AI <onboarding@resend.dev>
# If RESEND_FROM is omitted, BREVO_FROM or GMAIL_USER is used (must still be Resend-verified).

# AI — UI + Stitch orchestration: at least one provider (Gemini / Groq / OpenRouter / NVIDIA / etc.)
# Multi-model UI pipeline order: GEMINI_API_KEY → GROQ_API_KEY → AI_PRIMARY_* / OPENROUTER → NVIDIA → …
# (See src/lib/multi-model-completion.ts and src/lib/ai-provider-registry.ts)

# Google Gemini (recommended primary for structured UI JSON + landing HTML)
# GEMINI_API_KEY=
# GEMINI_MODEL_ID=gemini-2.0-flash

# Groq — fast OpenAI-compatible fallback (https://console.groq.com)
# GROQ_API_KEY=
# GROQ_MODEL_ID=llama-3.3-70b-versatile
# GROQ_UPSTREAM_TIMEOUT_MS=90000

# Hugging Face Inference API (optional last resort before template fallback)
# HUGGINGFACE_API_TOKEN=
# HUGGINGFACE_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2
# HUGGINGFACE_UPSTREAM_TIMEOUT_MS=60000

# AI — classic stack (see resolution order in src/lib/nim-client.ts)
# Orchestration Brain priority: AI_PRIMARY_* → OPENROUTER_API_KEY → NVIDIA_API_KEY → DEEPSEEK_API_KEY
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
NVIDIA_API_KEY=

# Optional — force primary to any OpenAI-compatible base URL + key (overrides env order above)
# AI_PRIMARY_API_URL=https://api.example.com/v1
# AI_PRIMARY_API_KEY=

# Optional — OpenRouter HTTP-Referer (defaults: NEXT_PUBLIC_APP_URL, then https://VERCEL_URL on Vercel, else localhost)
# OPENROUTER_HTTP_REFERER=https://your-app.example

# Default chat model (if unset: OpenRouter → openai/gpt-4o-mini, NVIDIA → llama 70B, DeepSeek → deepseek-chat)
# AI_MODEL_ID=

# Orchestration Brain: fast tier for matching / validation (defaults to AI_MODEL_ID)
# AI_FAST_MODEL_ID=

# Stitch landing only — fast model (defaults: OpenRouter → openai/gpt-4o-mini, else AI_FAST_MODEL_ID / AI_MODEL_ID)
# AI_STITCH_MODEL_ID=openai/gpt-4o-mini

# Task-specific models (orchestration routes different workloads — optional; reduces timeouts by using fast models for JSON throughput)
# Defaults: architecture + prompts + code → AI_MODEL_ID | structured JSON → AI_FAST_MODEL_ID | matching/validation → AI_FAST_MODEL_ID
# AI_MODEL_ARCHITECTURE_ID=
# AI_MODEL_PROMPTS_ID=
# AI_MODEL_STRUCTURED_JSON_ID=
# AI_MODEL_CODE_ID=

# Architecture analysis: default = one merged LLM call (fast). Set to 1 to force legacy two-phase (2 calls) for debugging.
# AI_ANALYZE_TWO_PHASE=0

# Stitch: upstream HTTP timeout ms (default 52000). Stay under Vercel Hobby ~60s so the route returns JSON instead of 504.
# STITCH_UPSTREAM_TIMEOUT_MS=52000

# Same primary endpoint only — alternate model when primary errors or returns empty output
# AI_FALLBACK_MODEL_ID=

# Secondary OpenAI-compatible API (e.g. native DeepSeek while primary is OpenRouter)
# AI_SECONDARY_API_URL=https://api.deepseek.com/v1
# AI_SECONDARY_API_KEY=
# AI_SECONDARY_MODEL_ID=deepseek-chat

# Last-resort: Cloudflare Workers AI REST (needs Account ID from dashboard → Workers AI → Use REST API)
# CLOUDFLARE_AI_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# Vercel: avoid 504 timeouts — compact AI chain + 8s upstream default (Hobby ~10s limit). Set to 1 on Pro for full multi-model + longer upstream (also set AI_UPSTREAM_TIMEOUT_MS).
# VERCEL_AI_FULL_CHAIN=1

# Optional — disable second-pass UI JSON polish (default: enabled locally; disabled automatically on Vercel compact). Set to 0 to skip extra model call.
# UI_JSON_ENHANCE=0

# Optional — per-request timeout to the AI API in ms (default 270000 ≈ 4.5 min). On Vercel Hobby (~60s route limit), try 45000–52000.
# AI_UPSTREAM_TIMEOUT_MS=270000

# Architecture + generate-prompts: max_tokens sent to the model is capped at this value (default 2048) to avoid OpenRouter HTTP 402 when credits only cover smaller completions. Raise (e.g. 8192) when you have balance.
# AI_MAX_COMPLETION_TOKENS=2048

# Optional — OpenAI SDK automatic retries (0–4, default 2). Set 0 on Hobby to avoid extra latency on flaky responses.
# AI_OPENAI_MAX_RETRIES=0

# Optional
# STITCH_API_KEY=

# Upstash Redis Cache (Used for Architecture and Prompts deterministic caching)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Playwright E2E (test Firebase project + Vercel preview only; never set E2E_SETUP_SECRET in Production) ---
# PLAYWRIGHT_BASE_URL=https://your-preview.vercel.app
# E2E_SETUP_SECRET=long-random-secret
# E2E_CREATOR_EMAIL=creator@test.example
# E2E_DEVELOPER_EMAIL=developer@test.example
# NEXT_PUBLIC_ENABLE_E2E_SIGNIN=true
# Optional: E2E_CREATOR_PASSWORD= / E2E_DEVELOPER_PASSWORD= for auth.spec password login when .auth JSON is not used
# Optional: E2E_STRICT_API=1 to fail tests on 5xx from same-origin /api/*
# Optional: E2E_SKIP_COMPLETION=1 to skip the long completion.spec.ts
